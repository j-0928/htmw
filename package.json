{
    "name": "htmw-mcp",
    "version": "1.0.0",
    "description": "MCP server for HowTheMarketWorks.com stock trading simulator",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "build": "tsc && ([ -z \"$DATABASE_URL\" ] || npx drizzle-kit push) && (mkdir -p dist/public && cp -r src/public/* dist/public/ || true)",
        "postinstall": "npm run build",
        "start": "node dist/server.js",
        "stdio": "node dist/index.js",
        "serve": "node dist/server.js",
        "dev": "tsc --watch"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "@types/express": "^5.0.6",
        "axios": "^1.13.4",
        "cheerio": "^1.0.0",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "express": "^5.2.1",
        "https-proxy-agent": "^7.0.6",
        "pg": "^8.20.0",
        "tough-cookie": "^4.1.3",
        "undici": "^7.20.0"
    },
    "devDependencies": {
        "@types/eventsource": "^1.1.15",
        "@types/node": "^20.0.0",
        "@types/pg": "^8.18.0",
        "@types/tough-cookie": "^4.0.5",
        "drizzle-kit": "^0.31.10",
        "eventsource": "^4.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.0.0"
    }
}
